VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Vercel Environment Variables): ZR Express API key for X-Api-Key on api.zrexpress.app
ZR_API_KEY=
# Optional: override X-Tenant for territories/search (defaults to delivery_companies.tenant_id)
# ZR_TENANT_ID=
# Public origin for ZR webhook registration (e.g. https://your-app.vercel.app). Falls back to VERCEL_URL.
# ZR_WEBHOOK_PUBLIC_URL=

# Browser → Vercel API routes (validate-shipment, register-zr-webhook, zr-territories-search)
# VITE_API_ORIGIN=https://your-app.vercel.app
